# =====================================================
# VARIABLES DE ENTORNO - Copia este archivo como .env
# =====================================================

APP_NAME="ShopFlow API"
APP_VERSION="1.0.0"
DEBUG=True

# SQLite para desarrollo. Para producción cambia a PostgreSQL:
# DATABASE_URL=postgresql://usuario:password@localhost:5432/shopflow
DATABASE_URL=sqlite:///./shopflow.db

# JWT - CAMBIAR EN PRODUCCIÓN
# Genera una clave segura con: openssl rand -hex 32
SECRET_KEY=clave-super-secreta-cambiar-en-produccion-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
