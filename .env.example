# =====================================================
# VARIABLES DE ENTORNO - Copia este archivo como .env
# =====================================================

# Nombre de la aplicación
APP_NAME="TaskFlow API"
APP_VERSION="1.0.0"
DEBUG=True

# Base de datos (SQLite por defecto, fácil de usar en desarrollo)
# Para producción: postgresql://usuario:password@localhost:5432/taskflow
DATABASE_URL=sqlite:///./taskflow.db

# JWT - CAMBIAR ESTA CLAVE EN PRODUCCIÓN
# Genera una clave segura con: openssl rand -hex 32
SECRET_KEY=clave-super-secreta-cambiar-en-produccion-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
